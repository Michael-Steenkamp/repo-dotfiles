/* Wallust Rofi Template - Classical Dark Mode */

* {
    /* 1. Define Variables */
    back: {{background}};
    text: {{foreground}};
    accent: {{color2}};
    urgent: {{color1}};

    /* 2. Map to Rofi System */
    background-color: @back;
    text-color: @text;

    margin: 0px;
    padding: 0px;
    spacing: 0px;
}

window {
    background-color: @back;
    border: 2px;
    border-color: @accent;
    border-radius: 10px;
    padding: 10px;
    width: 30%;
}

inputbar {
    padding: 10px;
    children: [ prompt, entry ];
    background-color: @back;
}

prompt {
    background-color: @back;
    text-color: @accent;
    font: "JetBrainsMono Nerd Font Bold 12";
    padding: 0px 10px 0px 0px;
}

entry {
    background-color: @back;
    text-color: @text;
    placeholder: "Search...";
}

listview {
    lines: 10;
    scrollbar: false;
    spacing: 5px;
    margin: 10px 0px 0px 0px;
    background-color: @back;
}

/* FIX: Explicitly target the elements to prevent "Alternating Beige" */
element {
    padding: 8px;
    border-radius: 5px;
    background-color: @back;
    text-color: @text;
}

element normal.normal, element alternate.normal {
    background-color: @back;
    text-color: @text;
}

element selected.normal {
    background-color: @accent;
    text-color: @back; /* Invert text color on selection */
}

element-text {
    background-color: inherit;
    text-color: inherit;
    vertical-align: 0.5;
}

element-icon {
    size: 24px;
    margin: 0px 10px 0px 0px;
    background-color: transparent;
}
