;; --- Variables ---
(defvar sidebar_visible false) ;; <--- NEW: Tracks main sidebar state
(defvar popup_visible false)   ;; <--- Tracks center popup state

;; --- Sidebar Polls (Lightweight) ---
;; These only run when the main sidebar is open
(defpoll net_ssid  :interval "2s" :run-while sidebar_visible "~/.config/eww/scripts/net.py ssid")
(defpoll net_icon  :interval "2s" :run-while sidebar_visible "~/.config/eww/scripts/net.py icon")
(defpoll bt_device :interval "5s" :run-while sidebar_visible "~/.config/eww/scripts/bt.py status")

(defpoll current_vol :interval "1s" :initial "0" :run-while sidebar_visible "pamixer --get-volume")
(defpoll current_bri :interval "1s" :initial "0" :run-while sidebar_visible "brightnessctl -m | awk -F, '{print substr($4, 0, length($4)-1)}'")

;; Music Listener (Instant Updates)
(deflisten music :initial '{"title": "No Music", "artist": "", "status": "Stopped", "icon": "󰐊"}'
                 "~/.config/eww/scripts/music.py")

;; --- Popup Polls (Heavyweight) ---
;; These only run when the center popup is actually open
(defpoll wifi_list :interval "10s" :initial "[]" :run-while popup_visible "~/.config/eww/scripts/net.py list")
(defpoll bt_list   :interval "5s"  :initial "[]" :run-while popup_visible "~/.config/eww/scripts/bt.py list")

;; Status checks for the Toggle Buttons inside the popup
(defpoll net_status :interval "2s" :run-while popup_visible "nmcli networking")
(defpoll bt_status  :interval "2s" :run-while popup_visible "rfkill list bluetooth | grep -q 'Soft blocked: yes' && echo 'off' || echo 'on'")

;; --- Other Variables ---
(defvar dnd_status "Off")
(defvar pwr_profile "Performance")
(defvar vol_reveal false)
(defvar bri_reveal false)
(defvar music_opt_icon "")
(defvar active_view 0)

;; --- Windows ---

(defwindow sidebar
  :monitor 0
  :geometry (geometry :x "10px"
                      :y "70px"
                      :width "300px"
                      :height "80%"
                      :anchor "center right")
  :stacking "overlay"
  :exclusive false
  :focusable false
  (sidebar_layout))

(defwindow center_popup
  :monitor 0
  :geometry (geometry :x "0%"
                      :y "0%"
                      :width "400px"
                      :height "300px"
                      :anchor "center center")
  :stacking "overlay"
  (popup_layout))


;; --- Layout Definitions ---

(defwidget sidebar_layout []
  (box :class "main-container"
       :orientation "v"
       :space-evenly false
       :spacing 15

    ;; 1. Top Grid (2x2)
    (box :class "grid-section" :orientation "v" :spacing 10
      (box :orientation "h" :spacing 10
        (grid_btn :label "" :value net_ssid :icon net_icon :target 1)
        (grid_btn :label "" :value bt_device :icon "󰂯" :target 2))
      (box :orientation "h" :spacing 10
        (grid_btn :label "DND" :value dnd_status :icon "󰂛" :target 3)
        (grid_btn :label "PWR" :value pwr_profile :icon "󰐥" :target 4)))

    ;; 2. Circular Controls & Sliders
    (box :class "controls-container"
         :orientation "v"
         :space-evenly false
         :spacing 5

      ;; The Row of Buttons
      (box :class "circles-section" :orientation "h" :spacing 20 :halign "center"
        ;; Volume: Added :classname "vol-btn"
        (circle_btn :icon "󰕾"
                    :active vol_reveal
                    :classname "vol-btn"
                    :action "eww update vol_reveal=${!vol_reveal} bri_reveal=false")

        ;; Brightness: Added :classname "bri-btn"
        (circle_btn :icon "󰃠"
                    :active bri_reveal
                    :classname "bri-btn"
                    :action "eww update bri_reveal=${!bri_reveal} vol_reveal=false")

        ;; Screenshot & Empty
        (circle_btn :icon "󰄄" :action "notify-send 'Screenshot' 'Taking shot...'")
        (circle_btn :icon "󰚨" :action "notify-send 'Empty' 'Nothing here'"))

      ;; Volume Slider (Reveals when vol_reveal is true)
      (revealer :transition "slidedown"
                :reveal vol_reveal
                :duration "350ms"
        (box :class "slider-box" :orientation "h" :space-evenly false
             ;; Removed the "Vol" label
             (scale :class "vol-scale"
                    :hexpand true   ;; <--- Forces it to fill width
                    :min 0
                    :max 101
                    :value current_vol
                    ;; printf rounds the float to int (e.g. 50.4 -> 50)
                    :onchange "pamixer --set-volume $(printf '%.0f' {})")))

      ;; Brightness Slider (Reveals when bri_reveal is true)
      (revealer :transition "slidedown"
                :reveal bri_reveal
                :duration "350ms"
        (box :class "slider-box" :orientation "h" :space-evenly false
             ;; Removed the "Bri" label
             (scale :class "bri-scale"
                    :hexpand true   ;; <--- Forces it to fill width
                    :min 0
                    :max 101
                    :value current_bri
                    :onchange "brightnessctl s {}%"))))

    ;; 3. Media Player
    (box :class "media-section" :orientation "v" :space-evenly false
      (label :class "media-title" :text "Now Playing")

      ;; Song Title
      (label :class "media-song"
             :text {music.title}
             :limit-width 25)

      ;; Artist Name
      (label :class "media-artist"
             :text {music.artist}
             :limit-width 25)

      ;; Controls
      (box :class "media-controls" :orientation "h" :halign "center" :spacing 20
         (button :onclick "playerctl -p spotify_player previous" "󰒮")

         ;; Dynamic Play/Pause Button
         (button :onclick "~/.config/eww/scripts/music-toggle.sh &"
                 ;; Show override if set, otherwise show real icon
                 {music_opt_icon != "" ? music_opt_icon : music.icon})

         (button :onclick "playerctl -p spotify_player next" "󰒭")))

    ;; 4. Calendar
    (box :class "calendar-section"
      (calendar :day 25 :year 2025))

    ;; 5. Notifications
    (box :class "notif-section" :orientation "v" :space-evenly false
      (label :class "section-header" :text "Notifications" :halign "start")
      (scroll :hscroll false :vscroll true :height 150
        (box :orientation "v" :spacing 10
          (label :text "Discord: New Message" :halign "start")
          (label :text "System: Update Available" :halign "start")
          (label :text "Spotify: Liked Song" :halign "start"))))
  ))

(defwidget popup_layout []
  (box :class "popup-container"
       :orientation "v"
       :space-evenly false

    ;; Header with Close Button
    (box :orientation "h" :halign "end" :space-evenly false
         (button :class "close-btn" :onclick "eww update active_view=0 && eww close center_popup" ""))

    (stack :selected active_view :transition "slideleft"

      ;; 0. Placeholder
      (label :text "Select an item..." :class "placeholder-text")

      ;; 1. Network View
      (box :orientation "v" :spacing 15 :space-evenly false
           (label :class "popup-header" :text "Wi-Fi Networks")
           (box :orientation "h" :spacing 15
             ;; Toggle Button (Green if On)
             (button :class "action-btn ${net_status == 'enabled' ? 'active' : ''}"
                     :onclick "~/.config/hypr/scripts/toggle-network.sh"
                     "${net_status == 'enabled' ? 'On 󰖩' : 'Off 󰖪'}")
             (button :class "action-btn" :onclick "~/.config/eww/scripts/net.py scan" "Refresh "))

           (scroll :hscroll false :vscroll true :height 200
             (box :orientation "v" :spacing 5
               (for net in wifi_list
                 (button :class "list-item" :halign "fill" :onclick "nmcli device wifi connect '${net.ssid}' &"
                   (box :orientation "h" :space-evenly true
                     (label :halign "start" :text "${net.ssid}" :limit-width 15)
                     (box :orientation "h" :halign "end" :spacing 10
                       (label :text "${net.sec}")
                       (label :text "${net.signal}%"))))))))

      ;; 2. Bluetooth View
      (box :orientation "v" :spacing 15 :space-evenly false
           (label :class "popup-header" :text "Bluetooth Devices")
           (box :orientation "h" :spacing 15
             ;; Toggle Button (Green if On)
             (button :class "action-btn ${bt_status == 'on' ? 'active' : ''}"
                     :onclick "~/.config/hypr/scripts/toggle-bluetooth.sh"
                     "${bt_status == 'on' ? 'On 󰂯' : 'Off 󰂲'}")
             (button :class "action-btn" :onclick "overskride &" "Manager "))

           (scroll :hscroll false :vscroll true :height 200
             (box :orientation "v" :spacing 5
               (for device in bt_list
                 (button :class "list-item" :halign "fill"
                         :onclick "~/.config/eww/scripts/bt.py connect ${device.mac} ${device.action} &"
                   (box :orientation "h" :space-evenly true
                     (box :orientation "h" :space-evenly false :spacing 10
                       (label :text "${device.icon}" :style "color: ${device.color}; font-size: 16px;")
                       (label :text "${device.name}" :limit-width 15))
                     (label :halign "end" :text "${device.status_text}" :style "font-size: 10px; color: ${device.color};")))))))

      ;; 3. DND View
      (box :orientation "v" :spacing 10 :space-evenly false
           (label :class "popup-header" :text "Do Not Disturb")
           (button :class "list-item" "1 Hour")
           (button :class "list-item" "Until I leave"))

      ;; 4. Power View
      (box :orientation "v" :spacing 10 :space-evenly false
           (label :class "popup-header" :text "Power Profiles")
           (button :class "list-item" "Performance")
           (button :class "list-item" "Power Saver"))
    )))

;; --- Helper Widgets ---

(defwidget grid_btn [label value icon target]
  (button :class "grid-btn ${active_view == target ? 'active' : ''}"
          :onclick "eww update active_view='${target}' && eww open center_popup"
    (box :orientation "v" :space-evenly false :valign "center"
      (label :class "grid-icon" :text icon)
      (label :class "grid-label" :text label :visible {label != ""})
      (label :class "grid-value" :text value :limit-width 12))))

(defwidget circle_btn [icon action ?active ?classname]
  (button :class "circle-btn ${active == true ? 'active' : ''} ${classname}"
          :onclick action
    (label :text icon)))

(defvar icon-hover-state false)

